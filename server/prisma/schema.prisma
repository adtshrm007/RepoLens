// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AuthProvider {
  CUSTOM
  GOOGLE
  GITHUB
}

model User {
  id String @id @default(cuid())

  name     String
  email    String @unique
  username String?

  password String?

  provider AuthProvider @default(CUSTOM)

  profilePic String?

  githubId    String? @unique
  googleId    String? @unique

  githubAccessToken  String?
  githubRefreshToken String?

  appRefreshToken String?

  isEmailVerified Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  repositories Repository[]
  fileDocs     FileDocumentation[]
}

model Repository {
  id String @id @default(cuid())

  name         String
  fullName     String
  githubRepoId String
  repoUrl      String
  isPrivate    Boolean
  language     String?

  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  analyses Analysis[]
}

model Analysis {
  id String @id @default(cuid())

  repositoryId String

  overallScore         Float?
  securityScore        Float?
  maintainabilityScore Float?

  status  String
  summary String?

  createdAt DateTime @default(now())

  repository Repository @relation(fields: [repositoryId], references: [id])

  findings Finding[]
}

model Finding {
  id String @id @default(cuid())

  analysisId String

  category    String
  severity    String
  issue       String
  reason      String
  suggestion  String
  filePath    String
  lineNumber  Int?
  codeSnippet String?

  analysis Analysis @relation(fields: [analysisId], references: [id])
}

model FileDocumentation {
  id           String @id @default(cuid())
  
  repoFullName String // e.g. "owner/repoName"
  filePath     String
  
  purpose      String?
  architecture String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId       String
  user         User     @relation(fields: [userId], references: [id])

  @@unique([userId, repoFullName, filePath])
}
