// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AuthProvider {
  CUSTOM
  GOOGLE
  GITHUB
}

model User {
  id String @id @default(cuid())

  name     String
  email    String  @unique
  username String?

  password String?

  provider AuthProvider @default(CUSTOM)

  profilePic String?

  githubId String? @unique
  googleId String? @unique

  githubAccessToken  String?
  githubRefreshToken String?

  appRefreshToken String?

  isEmailVerified Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  repositories Repository[]
  fileDocs     FileDocumentation[]
}

model Repository {
  id String @id @default(cuid())

  name         String
  fullName     String
  githubRepoId String
  repoUrl      String
  isPrivate    Boolean
  language     String?

  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  scans RepositoryScan[]
}

model RepositoryScan {
  id String @id @default(cuid())

  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id])

  status        String   // "SCANNING", "ANALYZING", "COMPLETED", "FAILED"
  totalFiles    Int      @default(0)
  analyzedFiles Int      @default(0)
  
  summary       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  files            RepositoryFile[]
  securityFindings SecurityFinding[]
  healthScore      HealthScore?
  architecture     ArchitectureModel?
  onboardingGuide  OnboardingGuide?
  dependencyGraph  DependencyGraph?
}

model RepositoryFile {
  id String @id @default(cuid())

  scanId String
  scan   RepositoryScan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  path            String
  extension       String
  size            Int
  isAnalyzed      Boolean @default(false)
  importanceScore Int?

  classification FileClassification?
  metrics        FileMetrics?
}

model FileClassification {
  id String @id @default(cuid())
  
  fileId String @unique
  file   RepositoryFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  type String // "Context Provider", "Component", "Service", "Route", etc.
}

model FileMetrics {
  id String @id @default(cuid())
  
  fileId String @unique
  file   RepositoryFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  linesOfCode       Int
  functionCount     Int
  componentCount    Int
  hookUsage         Int
  avgFunctionLength Float
  largestFunction   Int
  nestingDepth      Int
  dependencyCount   Int
  deadCodeIndicators Int @default(0)
}

model SecurityFinding {
  id String @id @default(cuid())

  scanId String
  scan   RepositoryScan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  type        String
  severity    String // "CRITICAL", "HIGH", "MEDIUM", "LOW"
  file        String
  lineNumber  Int
  snippet     String
  description String
  recommendation String?
}

model DependencyGraph {
  id String @id @default(cuid())

  scanId String @unique
  scan   RepositoryScan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  nodes Json
  edges Json
}

model HealthScore {
  id String @id @default(cuid())

  scanId String @unique
  scan   RepositoryScan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  maintainability Int
  security        Int
  architecture    Int
  documentation   Int
  overall         Int
}

model ArchitectureModel {
  id String @id @default(cuid())

  scanId String @unique
  scan   RepositoryScan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  frontendLayer String?
  apiLayer      String?
  serviceLayer  String?
  dataLayer     String?
  authLayer     String?
  
  summary       String?
}

model OnboardingGuide {
  id String @id @default(cuid())

  scanId String @unique
  scan   RepositoryScan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  content     String
  entryPoints Json
  moduleFlow  Json
}

model FileDocumentation {
  id String @id @default(cuid())

  repoFullName String
  filePath     String

  purpose      String?
  architecture String?
  source       String  @default("analysis")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@unique([userId, repoFullName, filePath])
}
